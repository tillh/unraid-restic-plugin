    <p class="restic-note">Commands: <code>restic version</code>, <code>restic-manager status</code>, <code>restic-manager update</code>.</p>
    <div class="restic-message" id="restic-message"></div>
  </div>
</div>

<script>
(() => {
  const apiPath = '/plugins/restic/scripts/restic-api.php';
  const csrfToken = <?php echo json_encode($csrfToken, JSON_UNESCAPED_SLASHES | JSON_UNESCAPED_UNICODE); ?>;
  const installButton = document.getElementById('restic-install-update-button');
  const removeButton = document.getElementById('restic-remove-button');
  const installedVersion = document.getElementById('restic-installed-version');
  const latestVersion = document.getElementById('restic-latest-version');
  const binaryPath = document.getElementById('restic-binary-path');
  const managerPath = document.getElementById('restic-manager-path');
  const message = document.getElementById('restic-message');

  async function request(action, method = 'GET') {
    const url = action === 'status' ? `${apiPath}?action=${encodeURIComponent(action)}` : apiPath;
    const options = { method };

    if (method !== 'GET') {
      options.headers = { 'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8' };
      options.body = `action=${encodeURIComponent(action)}&csrf_token=${encodeURIComponent(csrfToken)}`;
    }

    const response = await fetch(url, options);
    const payload = await response.json();

    if (!response.ok || payload.success === false) {
      throw new Error(payload.error || payload.message || 'Request failed');
    }

    return payload;
  }

  function setBusy(isBusy) {
    installButton.disabled = isBusy;
    removeButton.disabled = isBusy;
  }

  function setMessage(text, isError = false) {
    message.textContent = text || '';
    message.classList.toggle('is-error', Boolean(isError));
  }

  function renderStatus(status) {
    installedVersion.textContent = status.installed ? (status.installedVersion || 'Unknown') : 'Not installed';
    latestVersion.textContent = status.latestVersion || 'Unavailable';
    binaryPath.textContent = status.binaryPath || '/usr/local/bin/restic';
    managerPath.textContent = status.managerPath || '/usr/local/sbin/restic-manager';

    if (!status.installed) {
      installButton.hidden = false;
      installButton.textContent = status.latestVersion ? `Install ${status.latestVersion}` : 'Install latest';
      removeButton.hidden = true;
      return;
    }

    removeButton.hidden = false;

    if (status.updateAvailable) {
      installButton.hidden = false;
      installButton.textContent = `Update to ${status.latestVersion}`;
    } else {
      installButton.hidden = true;
      installButton.textContent = 'Install latest';
    }
  }

  async function refreshStatus(messageText = '') {
    setBusy(true);

    try {
      const payload = await request('status');
      renderStatus(payload.status);
      setMessage(messageText || payload.status.note || '', false);
    } catch (error) {
      setMessage(error.message, true);
      installedVersion.textContent = 'Unavailable';
      latestVersion.textContent = 'Unavailable';
    } finally {
      setBusy(false);
    }
  }

  installButton.addEventListener('click', async () => {
    setBusy(true);
    setMessage('Working...');

    try {
      const payload = await request('install', 'POST');
      renderStatus(payload.status);
      setMessage(payload.message || 'Completed.', false);
    } catch (error) {
      setMessage(error.message, true);
    } finally {
      setBusy(false);
    }
  });

  removeButton.addEventListener('click', async () => {
    if (!window.confirm('Remove the managed restic binary from this server?')) {
      return;
    }

    setBusy(true);
    setMessage('Removing...');

    try {
      const payload = await request('remove', 'POST');
      renderStatus(payload.status);
      setMessage(payload.message || 'Removed.', false);
    } catch (error) {
      setMessage(error.message, true);
    } finally {
      setBusy(false);
    }
  });

  refreshStatus();
})();
</script>
